{
  "manifest_version": 3,
  "name": "Leta Tab",
  "version": "3.2",
  "description": "Set your own New Tab page in Firefox, and change it any time from a small popup.",
  "browser_specific_settings": {
    "gecko": {
      "id": "letatab@letalab.eu",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    },
    "gecko_android": {
      "strict_min_version": "142.0"
    }
  },
  "permissions": ["storage"],
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "LetaTab",
    "default_icon": {
      "16": "favicon-16.png",
      "32": "favicon-32.png",
      "48": "favicon.png",
      "128": "favicon-128.png"
    }
  },
  "icons": {
    "16": "favicon-16.png",
    "32": "favicon-32.png",
    "48": "favicon.png",
    "128": "favicon-128.png"
  }
}
